.guide-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 180rpx;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  pointer-events: none;
}

/* 俯视图: 竖椭圆 (头长方向垂直) */
.guide-ellipse-top {
  width: 380rpx; height: 460rpx;
  border: 4rpx dashed rgba(59, 130, 246, 0.5);
  border-radius: 50%;
}

/* 侧面图: 横椭圆 (头长方向水平) */
.guide-ellipse-side {
  width: 480rpx; height: 340rpx;
  border: 4rpx dashed rgba(99, 102, 241, 0.5);
  border-radius: 50%;
}

.guide-text {
  margin-top: 28rpx;
  font-size: 28rpx; color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.6);
}
.guide-sub {
  margin-top: 6rpx;
  font-size: 24rpx; color: rgba(255, 255, 255, 0.65);
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.6);
}

.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  height: 180rpx;
  background: rgba(0, 0, 0, 0.35);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 20rpx;
}

.btn-capture {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex; align-items: center; justify-content: center;
}
.btn-inner {
  width: 90rpx; height: 90rpx;
  border-radius: 50%;
  background: #fff;
}

.btn-cancel {
  font-size: 28rpx; color: rgba(255, 255, 255, 0.7);
  padding: 8rpx 24rpx;
}

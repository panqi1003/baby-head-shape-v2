/* 引导框覆盖层 */
.guide-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 180rpx;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  pointer-events: none;
}

/* 椭圆框 */
.guide-ellipse {
  width: 400rpx; height: 480rpx;
  border: 4rpx dashed rgba(59, 130, 246, 0.6);
  border-radius: 50%;
}

/* 提示文字 */
.guide-text {
  margin-top: 32rpx;
  font-size: 32rpx; color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.6);
}
.guide-sub {
  margin-top: 8rpx;
  font-size: 26rpx; color: rgba(255, 255, 255, 0.7);
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.6);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  height: 180rpx;
  background: rgba(0, 0, 0, 0.4);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 20rpx;
}

/* 拍照按钮 */
.btn-capture {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex; align-items: center; justify-content: center;
}
.btn-inner {
  width: 90rpx; height: 90rpx;
  border-radius: 50%;
  background: #fff;
}

/* 返回文字 */
.btn-cancel {
  font-size: 28rpx; color: rgba(255, 255, 255, 0.8);
  padding: 8rpx 24rpx;
}

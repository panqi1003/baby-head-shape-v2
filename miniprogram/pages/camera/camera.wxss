/* 引导框覆盖层 */
.guide-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 180rpx;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  pointer-events: none;
}

/* 俯视图椭圆 (竖) */
.guide-ellipse-top {
  width: 380rpx; height: 460rpx;
  border: 4rpx dashed rgba(59, 130, 246, 0.6);
  border-radius: 50%;
}

/* 侧面图椭圆 (横) */
.guide-ellipse-side {
  width: 460rpx; height: 340rpx;
  border: 4rpx dashed rgba(99, 102, 241, 0.6);
  border-radius: 50%;
}

/* 鼻尖方向箭头 — 在椭圆上方 */
.nose-arrow {
  position: absolute;
  margin-top: -260rpx;
  font-size: 40rpx;
  color: rgba(59, 130, 246, 0.7);
}
.nose-label {
  position: absolute;
  margin-top: -218rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.6);
}

/* 耳位参考点 — 在椭圆左侧 */
.ear-marker {
  position: absolute;
  font-size: 24rpx;
  color: rgba(99, 102, 241, 0.8);
}
.ear-left {
  margin-left: -250rpx;
}
.ear-label {
  position: absolute;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.6);
}
.ear-label-left {
  margin-left: -250rpx;
  margin-top: 28rpx;
}

/* 提示文字 */
.guide-text {
  margin-top: 28rpx;
  font-size: 28rpx; color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.6);
  text-align: center;
  padding: 0 40rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  height: 180rpx;
  background: rgba(0, 0, 0, 0.4);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 20rpx;
}

/* 拍照按钮 */
.btn-capture {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex; align-items: center; justify-content: center;
}
.btn-inner {
  width: 90rpx; height: 90rpx;
  border-radius: 50%;
  background: #fff;
}

/* 返回文字 */
.btn-cancel {
  font-size: 28rpx; color: rgba(255, 255, 255, 0.8);
  padding: 8rpx 24rpx;
}

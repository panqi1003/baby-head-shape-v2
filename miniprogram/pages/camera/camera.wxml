<camera device-position="back" flash="off" binderror="onCameraError" style="width:100%;height:100vh;">

  <!-- 引导框 -->
  <cover-view class="guide-overlay">
    <!-- 俯视图: 竖椭圆 (头长>头宽) -->
    <cover-view wx:if="{{photoType === 'top'}}" class="guide-ellipse-top"></cover-view>
    <!-- 侧面图: 横椭圆 (前后>上下) -->
    <cover-view wx:if="{{photoType === 'side'}}" class="guide-ellipse-side"></cover-view>

    <cover-view class="guide-text">前后移动手机</cover-view>
    <cover-view class="guide-sub">让宝宝头部填满椭圆框</cover-view>
  </cover-view>

  <cover-view class="bottom-bar">
    <cover-view class="btn-capture" bindtap="takePhoto">
      <cover-view class="btn-inner"></cover-view>
    </cover-view>
    <cover-view class="btn-cancel" bindtap="goBack">返回</cover-view>
  </cover-view>
</camera>

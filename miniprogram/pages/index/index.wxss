.page { padding-bottom: 180rpx; }

/* 顶部 */
.header {
  background: linear-gradient(135deg, #3b82f6, #6366f1);
  padding: 40rpx 30rpx;
  display: flex; align-items: center; gap: 20rpx;
}
.header-title { font-size: 36rpx; font-weight: 700; color: #fff; display: block; }
.header-sub  { font-size: 24rpx; color: rgba(255,255,255,0.7); display: block; margin-top: 4rpx; }

/* 卡片标题 */
.section-head {
  display: flex; align-items: center; gap: 12rpx; margin-bottom: 24rpx;
}
.section-title { font-size: 30rpx; font-weight: 600; }

/* 指南 */
.guide-subtitle {
  font-size: 26rpx; font-weight: 600; color: #475569;
  margin: 20rpx 0 12rpx;
  padding-left: 4rpx;
}
.guide-row { display: flex; gap: 16rpx; }
.guide-tip {
  margin-top: 16rpx; padding: 14rpx 18rpx;
  background: #eff6ff; border-radius: 12rpx;
  font-size: 24rpx; color: #3b82f6; line-height: 1.5;
}
.guide-item {
  flex: 1; text-align: center;
  background: #f8fafc; border-radius: 16rpx; padding: 24rpx 8rpx;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}
.guide-label { font-size: 24rpx; font-weight: 500; color: #334155; }
.guide-desc  { font-size: 20rpx; color: #94a3b8; }

/* 照片区 */
.photo-section { margin-bottom: 28rpx; }
.photo-label-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.photo-label { font-size: 28rpx; font-weight: 500; }
.photo-box {
  width: 100%; height: 340rpx;
  border: 2rpx dashed #cbd5e1; border-radius: 20rpx;
  overflow: hidden; background: #fafafa;
}
.photo-placeholder {
  width: 100%; height: 100%;
  position: relative;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 12rpx;
}
.photo-text { color: #94a3b8; font-size: 28rpx; }
.photo-hint { font-size: 22rpx; color: #cbd5e1; }
.photo-preview { width: 100%; height: 100%; }

/* 引导框 */
.guide-frame {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
}
.guide-ellipse {
  width: 420rpx; height: 520rpx;
  border: 4rpx dashed #3b82f6;
  border-radius: 50%;
  opacity: 0.5;
}
.guide-text {
  margin-top: 24rpx; font-size: 28rpx; color: #3b82f6; font-weight: 500;
}
.guide-sub {
  font-size: 22rpx; color: #94a3b8; margin-top: 6rpx;
}

/* 已有照片时的参考线 */
.guide-frame-overlay {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  display: flex; align-items: center; justify-content: center;
  pointer-events: none;
}
.guide-ellipse-overlay {
  width: 420rpx; height: 520rpx;
  border: 2rpx solid rgba(255,255,255,0.4);
  border-radius: 50%;
}

/* 月龄输入 */
.input-row {
  display: flex; align-items: center; gap: 16rpx;
  padding: 24rpx 0; border-top: 1rpx solid #f1f5f9;
}
.input-label { font-size: 28rpx; font-weight: 500; }
.input-field {
  width: 120rpx; height: 60rpx;
  border: 1rpx solid #e2e8f0; border-radius: 12rpx;
  text-align: center; font-size: 28rpx; background: #f8fafc;
}
.input-unit { color: #94a3b8; font-size: 24rpx; }

/* 开关 */
.switch-row {
  display: flex; justify-content: space-between;
  padding: 24rpx 0; border-top: 1rpx solid #f1f5f9;
}
.switch-item { display: flex; align-items: center; gap: 12rpx; font-size: 28rpx; }

/* 提示 */
.hint-box {
  background: #fffbeb; border-radius: 12rpx;
  padding: 16rpx 20rpx; font-size: 24rpx; color: #92400e;
  display: flex; align-items: center; gap: 10rpx;
}

/* 底部 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 30rpx 50rpx;
  background: #fff; border-top: 1rpx solid #f1f5f9;
}
.disclaimer {
  text-align: center; font-size: 22rpx; color: #cbd5e1;
  display: block; margin-top: 16rpx;
}

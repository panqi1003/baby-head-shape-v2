<!-- 首页 -->
<view class="page">
  <view class="header">
    <van-icon name="smile-o" size="44rpx" color="#fff" />
    <view class="header-text">
      <text class="header-title">宝宝头型分析</text>
      <text class="header-sub">拍照测量 · 科学关注头型发育</text>
    </view>
  </view>

  <!-- 拍照指南 -->
  <view class="card">
    <view class="section-head">
      <van-icon name="info-o" size="36rpx" color="#3b82f6" />
      <text class="section-title">拍照指南</text>
    </view>

    <view class="guide-subtitle">俯视图</view>
    <view class="guide-row">
      <view class="guide-item">
        <van-icon name="photograph" size="36rpx" color="#3b82f6" />
        <text class="guide-label">引导框对齐</text>
        <text class="guide-desc">头型填满蓝色椭圆</text>
      </view>
      <view class="guide-item">
        <van-icon name="smile-o" size="36rpx" color="#3b82f6" />
        <text class="guide-label">鼻尖朝上</text>
        <text class="guide-desc">露出鼻尖，朝图片上方</text>
      </view>
    </view>

    <view class="guide-subtitle">侧面图</view>
    <view class="guide-row">
      <view class="guide-item">
        <van-icon name="photograph" size="36rpx" color="#6366f1" />
        <text class="guide-label">引导框对齐</text>
        <text class="guide-desc">头型填满紫色椭圆</text>
      </view>
      <view class="guide-item">
        <van-icon name="eye-o" size="36rpx" color="#6366f1" />
        <text class="guide-label">露出鼻梁+耳</text>
        <text class="guide-desc">完整侧面轮廓</text>
      </view>
    </view>

    <view class="guide-subtitle">提升精度</view>
    <view class="guide-row">
      <view class="guide-item">
        <van-icon name="gold-coin-o" size="36rpx" color="#f59e0b" />
        <text class="guide-label">放1元硬币</text>
        <text class="guide-desc">在头旁边校准</text>
      </view>
      <view class="guide-item">
        <van-icon name="like-o" size="36rpx" color="#22c55e" />
        <text class="guide-label">戴薄帽(可选)</text>
        <text class="guide-desc">浅色贴合头型</text>
      </view>
    </view>
  </view>

  <!-- 拍摄照片 -->
  <view class="card">
    <view class="section-head">
      <van-icon name="photo-o" size="36rpx" color="#3b82f6" />
      <text class="section-title">拍摄照片</text>
    </view>

    <!-- 俯视图 -->
    <view class="photo-label-row">
      <text class="photo-label">俯视图</text>
      <van-tag type="danger" size="mini">必填</van-tag>
    </view>
    <view class="photo-box" bindtap="takeTopPhoto" bindlongpress="chooseFromAlbum" data-type="top">
      <image wx:if="{{topPhoto}}" src="{{topPhoto}}" class="photo-preview" mode="aspectFill" />
      <view wx:else class="photo-placeholder">
        <van-icon name="photograph" size="40rpx" color="#cbd5e1" />
        <text class="photo-text">拍照或长按从相册选图</text>
      </view>
    </view>

    <!-- 右侧面图 -->
    <view class="photo-label-row" style="margin-top:24rpx">
      <text class="photo-label">侧面图（面朝右）</text>
      <van-tag type="primary" size="mini" plain>可选</van-tag>
    </view>
    <view class="photo-box" bindtap="takeRightSidePhoto" bindlongpress="chooseFromAlbum" data-type="right">
      <image wx:if="{{rightSidePhoto}}" src="{{rightSidePhoto}}" class="photo-preview" mode="aspectFill" />
      <view wx:else class="photo-placeholder">
        <van-icon name="photograph" size="40rpx" color="#cbd5e1" />
        <text class="photo-text">拍照或长按从相册选图</text>
      </view>
    </view>

    <!-- 月龄 + 开关 -->
    <view class="input-row">
      <text class="input-label">宝宝月龄</text>
      <van-tag type="danger" size="mini">必填</van-tag>
      <input class="input-field" type="number" placeholder="0-36" value="{{ageMonths}}" bindinput="onAgeInput" />
      <text class="input-unit">个月</text>
    </view>

    <view class="switch-row">
      <view class="switch-item">
        <text>参照物校准</text>
        <van-switch checked="{{useReference}}" bind:change="toggleReference" size="24px"
          active-color="#3b82f6" disabled="{{!hasReference}}" />
      </view>
      <view class="switch-item">
        <text>AI 分析</text>
        <van-switch checked="{{useAI}}" bind:change="toggleAI" size="24px" active-color="#3b82f6" />
      </view>
    </view>

    <view wx:if="{{refChecked && !hasReference}}" class="hint-box">
      <van-icon name="warning-o" size="28rpx" color="#d97706" />
      <text>照片中未检测到参照物，已自动使用估算比例。建议放入1元硬币后重新拍照。</text>
    </view>
  </view>

  <!-- 分析按钮 -->
  <view class="bottom-bar">
    <van-button type="primary" block round bind:click="startAnalyze"
      disabled="{{!topPhoto || analyzing}}" loading="{{analyzing}}" loading-text="分析中...">
      开始分析
    </van-button>
    <text class="disclaimer">照片仅用于头型分析，分析完成即删除，服务器不留存\n本工具仅供家庭参考，不构成医疗建议</text>
  </view>

  <van-toast id="van-toast" />
</view>

<!-- 首页: 拍照上传 -->
<view class="page">
  <!-- 顶部 -->
  <view class="header">
    <van-icon name="smile-o" size="44rpx" color="#fff" />
    <view class="header-text">
      <text class="header-title">宝宝头型分析</text>
      <text class="header-sub">拍照测量 · 科学关注头型发育</text>
    </view>
  </view>

  <!-- 拍照指南 -->
  <view class="card">
    <view class="section-head">
      <van-icon name="info-o" size="36rpx" color="#3b82f6" />
      <text class="section-title">拍照指南</text>
    </view>

    <!-- 俯视图要求 -->
    <view class="guide-subtitle">俯视图</view>
    <view class="guide-row">
      <view class="guide-item">
        <van-icon name="photograph" size="40rpx" color="#3b82f6" />
        <text class="guide-label">正上方垂直拍摄</text>
        <text class="guide-desc">前后移动对齐引导框</text>
      </view>
      <view class="guide-item">
        <van-icon name="smile-o" size="40rpx" color="#3b82f6" />
        <text class="guide-label">鼻尖朝上</text>
        <text class="guide-desc">必须露出鼻尖，朝图片上方</text>
      </view>
    </view>
    <view class="guide-tip">💡 将头型对准蓝色虚线框，填满后拍摄 = 无需硬币也能获得较准测量</view>

    <!-- 侧面图要求 -->
    <view class="guide-subtitle">侧面图 (可选)</view>
    <view class="guide-row">
      <view class="guide-item">
        <van-icon name="manager-o" size="40rpx" color="#6366f1" />
        <text class="guide-label">正侧躺拍摄</text>
        <text class="guide-desc">宝宝右侧或左侧躺</text>
      </view>
      <view class="guide-item">
        <van-icon name="eye-o" size="40rpx" color="#6366f1" />
        <text class="guide-label">露出鼻梁和耳朵</text>
        <text class="guide-desc">完整侧面轮廓可见</text>
      </view>
    </view>

    <!-- 通用建议 -->
    <view class="guide-row" style="margin-top:16rpx">
      <view class="guide-item">
        <van-icon name="gold-coin-o" size="40rpx" color="#f59e0b" />
        <text class="guide-label">放硬币(可选)</text>
        <text class="guide-desc">1元硬币=25mm，提高精度</text>
      </view>
      <view class="guide-item">
        <van-icon name="like-o" size="40rpx" color="#22c55e" />
        <text class="guide-label">建议戴薄帽</text>
        <text class="guide-desc">减少头发干扰</text>
      </view>
    </view>
  </view>

  <!-- 拍摄照片 -->
  <view class="card">
    <view class="section-head">
      <van-icon name="photo-o" size="36rpx" color="#3b82f6" />
      <text class="section-title">拍摄照片</text>
    </view>

    <!-- 俯视图 -->
    <view class="photo-section">
      <view class="photo-label-row">
        <text class="photo-label">俯视图</text>
        <van-tag type="danger" size="mini">必填</van-tag>
      </view>
      <view class="photo-box" bindtap="takeTopPhoto">
        <image wx:if="{{topPhoto}}" src="{{topPhoto}}" class="photo-preview" mode="aspectFill" />
        <view wx:else class="photo-placeholder">
          <!-- 引导框 -->
          <view class="guide-frame">
            <view class="guide-ellipse"></view>
            <text class="guide-text">前后移动手机</text>
            <text class="guide-sub">让头型恰好填满椭圆框</text>
          </view>
        </view>
        <!-- 已有照片时也显示引导框参考线 -->
        <view wx:if="{{topPhoto}}" class="guide-frame-overlay">
          <view class="guide-ellipse-overlay"></view>
        </view>
      </view>
    </view>

    <!-- 侧面图 -->
    <view class="photo-section">
      <view class="photo-label-row">
        <text class="photo-label">侧面图</text>
        <van-tag type="primary" size="mini" plain>选填</van-tag>
      </view>
      <view class="photo-box" bindtap="takeSidePhoto">
        <image wx:if="{{sidePhoto}}" src="{{sidePhoto}}" class="photo-preview" mode="aspectFill" />
        <view wx:else class="photo-placeholder">
          <van-icon name="add-o" size="56rpx" color="#cbd5e1" />
          <text class="photo-text">点击拍摄侧面图</text>
          <text class="photo-hint">用于分析后枕部扁平度</text>
        </view>
      </view>
    </view>

    <!-- 月龄 -->
    <view class="input-row">
      <text class="input-label">宝宝月龄</text>
      <input class="input-field" type="number" placeholder="选填" value="{{ageMonths}}" bindinput="onAgeInput" />
      <text class="input-unit">个月</text>
    </view>

    <!-- 开关 -->
    <view class="switch-row">
      <view class="switch-item">
        <text>参照物校准</text>
        <van-switch
          checked="{{useReference}}"
          bind:change="toggleReference"
          size="24px"
          active-color="#3b82f6"
          disabled="{{!hasReference}}"
        />
      </view>
      <view class="switch-item">
        <text>AI 分析</text>
        <van-switch checked="{{useAI}}" bind:change="toggleAI" size="24px" active-color="#3b82f6" />
      </view>
    </view>

    <view wx:if="{{refChecked && !hasReference}}" class="hint-box">
      <van-icon name="warning-o" size="28rpx" color="#d97706" />
      <text>照片中未检测到参照物，已自动使用估算比例。建议放入1元硬币后重新拍照。</text>
    </view>
    <view wx:elif="{{!useReference && hasReference}}" class="hint-box">
      <van-icon name="info-o" size="28rpx" color="#d97706" />
      <text>已关闭参照物校准，使用估算比例（精度较低）</text>
    </view>
  </view>

  <!-- 分析按钮 -->
  <view class="bottom-bar">
    <van-button type="primary" block round bind:click="startAnalyze"
      disabled="{{!topPhoto || analyzing}}" loading="{{analyzing}}"
      loading-text="分析中...">
      开始分析
    </van-button>
    <text class="disclaimer">本工具仅供家庭参考，不构成医疗建议</text>
  </view>

  <!-- toast 组件 -->
  <van-toast id="van-toast" />
</view>

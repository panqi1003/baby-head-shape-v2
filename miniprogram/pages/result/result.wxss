.page { padding-bottom: 180rpx; }

/* 卡片标题 */
.section-head {
  display: flex; align-items: center; gap: 12rpx; margin-bottom: 20rpx;
}
.section-title { font-size: 30rpx; font-weight: 600; flex: 1; }

/* 比例尺来源 + 置信度 并排 */
.meta-row {
  display: flex; gap: 16rpx; margin-top: 8rpx;
}
.meta-item {
  flex: 1; display: flex; align-items: center; gap: 8rpx;
  padding: 14rpx 16rpx; font-size: 22rpx; border-radius: 10rpx;
}
.meta-scale { background: #eff6ff; color: #3b82f6; }
.meta-conf  { background: #f0fdf4; color: #16a34a; }

/* 标注图 */
.annotated-img { width: 100%; border-radius: 16rpx 16rpx 0 0; }

/* 图例 */
.legend-row {
  display: flex; justify-content: center; gap: 24rpx;
  padding: 20rpx 16rpx; margin-bottom: 20rpx;
  background: #f8fafc; border-radius: 0 0 16rpx 16rpx;
  flex-wrap: wrap;
}
.legend-item { text-align: center; }
.legend-name { display: block; font-size: 22rpx; color: #64748b; margin-top: 4rpx; }
.legend-dot { width: 14rpx; height: 14rpx; border-radius: 50%; margin: 0 auto; }
.img-empty { text-align: center; padding: 60rpx 0; }

.scale-warn {
  margin-top: 16rpx; padding: 16rpx 20rpx;
  background: #fffbeb; border-radius: 12rpx;
  font-size: 24rpx; color: #92400e;
  display: flex; align-items: flex-start; gap: 10rpx; line-height: 1.5;
}

/* 数据网格 */
.data-grid { display: flex; flex-wrap: wrap; margin-top: 20rpx; }
.data-item {
  width: 50%; text-align: center; padding: 24rpx 12rpx; box-sizing: border-box;
  border-right: 1rpx solid #f1f5f9; border-bottom: 1rpx solid #f1f5f9;
}
.data-item:nth-child(2n) { border-right: none; }
.data-item:nth-child(n+5) { border-bottom: none; }
.data-value { font-size: 36rpx; font-weight: 700; color: #1e293b; display: block; }
.data-label { font-size: 24rpx; color: #64748b; display: block; margin-top: 6rpx; }
.data-explain { font-size: 20rpx; color: #94a3b8; display: block; margin-top: 6rpx; line-height: 1.5; }

/* 分析结论框 */
.analysis-box {
  margin-top: 20rpx; padding: 20rpx;
  background: #f0f9ff; border-radius: 14rpx;
  display: flex; align-items: flex-start; gap: 10rpx;
}
.analysis-box.side-box { background: #f5f3ff; }
.analysis-text { font-size: 26rpx; color: #334155; line-height: 1.6; flex: 1; }

/* 综合分析卡片 */
.combined-card { background: linear-gradient(135deg, #faf5ff, #eff6ff); border: 1rpx solid #e9d5ff; }

/* AI 内容 */
.ai-block { margin-bottom: 20rpx; }
.ai-explain { font-size: 28rpx; color: #334155; line-height: 1.7; }

/* 建议 */
.tips-block { margin-bottom: 16rpx; }
.tips-label { font-size: 28rpx; font-weight: 500; display: flex; align-items: center; gap: 8rpx; margin-bottom: 12rpx; }
.tip-item { font-size: 26rpx; color: #64748b; padding: 6rpx 0; display: block; }

/* 下一步 */
.next-box { margin-top: 20rpx; }

/* 报告导出 Canvas (隐藏) */
.report-canvas {
  position: fixed; left: -9999rpx; top: 0;
  width: 750rpx; height: 1200rpx;
}

/* 底部 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 30rpx 50rpx; background: #fff;
  border-top: 1rpx solid #f1f5f9;
}
.bottom-btn-row {
  display: flex; gap: 20rpx;
}
.btn-export { flex: 1; }
.btn-retake { flex: 1; }
.disclaimer {
  text-align: center; font-size: 22rpx; color: #cbd5e1;
  display: block; margin-top: 16rpx;
}

/* 标准头型对比 */
.compare-section {
  margin-top: 24rpx; padding: 20rpx;
  background: #faf5ff; border-radius: 16rpx;
  border: 2rpx solid #ede9fe;
}
.compare-head {
  display: flex; align-items: center; gap: 10rpx; margin-bottom: 14rpx;
}
.compare-title { font-size: 28rpx; font-weight: 600; color: #7c3aed; }
.compare-img {
  width: 100%; border-radius: 12rpx; border: 1rpx solid #e9d5ff;
}
.compare-legend {
  display: block; text-align: center; font-size: 20rpx;
  color: #a78bfa; margin-top: 10rpx;
}

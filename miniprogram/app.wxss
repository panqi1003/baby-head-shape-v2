page {
  --blue: #3b82f6;
  --green: #22c55e;
  --yellow: #eab308;
  --orange: #f97316;
  --red: #ef4444;
  --gray-bg: #f5f5f5;
  --gray-text: #6b7280;
  --border: #e5e7eb;

  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
  font-size: 28rpx;
  color: #1f2937;
  background-color: var(--gray-bg);
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

/* 通用按钮 */
.btn-primary {
  background: var(--blue);
  color: #fff;
  border-radius: 16rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
}
.btn-primary[disabled] {
  background: #d1d5db;
}

/* 严重程度颜色 */
.sev-normal { background: var(--green); }
.sev-mild   { background: var(--yellow); }
.sev-moderate { background: var(--orange); }
.sev-severe { background: var(--red); }

/* 标签 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #fff;
}
